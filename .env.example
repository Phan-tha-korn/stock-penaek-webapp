ESP_API_HOST=0.0.0.0
ESP_API_PORT=8000
ESP_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
ESP_ENV=production
ESP_JWT_SECRET=please-change
ESP_LOGIN_SECRET_PHRASE=please-change
