# Optional
ESP_REDIS_URL=

# Frontend (Vercel env)
VITE_API_URL=https://your-backend-domain.example.com/api
VITE_SOCKET_ENABLED=true
VITE_SOCKET_URL=https://your-backend-domain.example.com

